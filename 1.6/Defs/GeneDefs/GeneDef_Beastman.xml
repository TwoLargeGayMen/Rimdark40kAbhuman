<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Beastman: Goat Physique -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_BeastmanGoatPhysique</defName>
        <label>goat physique</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Beastmen/BEWH_GoatPhysique</iconPath>
        <biostatCpx>1</biostatCpx>
        <biostatMet>0</biostatMet>
        <displayOrderInCategory>81</displayOrderInCategory>

        <missingGeneRomanceChanceFactor>0.2</missingGeneRomanceChanceFactor>
        <forcedHeadTypes>
            <li>BEWH_BeastmanHead</li>
        </forcedHeadTypes>
        <beardTagFilter>
            <whitelist>true</whitelist>
            <tags>
                <li>BeardLong</li>
                <li>Furskin</li>
            </tags>
        </beardTagFilter>
        <exclusionTags>
            <li>HairStyle</li>
            <li>Fur</li>
            <li>BeardStyle</li>
        </exclusionTags>
        <statOffsets>
            <ComfyTemperatureMin>-15</ComfyTemperatureMin>
        </statOffsets>
        <fur>Furskin</fur>
        <skinIsHairColor>true</skinIsHairColor>
        <tattoosVisible>false</tattoosVisible>
        <renderNodeProperties>
            <li>
                <debugLabel>Fur</debugLabel>
                <nodeClass>PawnRenderNode_Fur</nodeClass>
                <workerClass>PawnRenderNodeWorker_Fur</workerClass>
                <baseLayer>5</baseLayer>
                <rotDrawMode>Fresh, Rotting</rotDrawMode>
                <colorType>Hair</colorType>
                <parentTagDef>Body</parentTagDef>
            </li>
        </renderNodeProperties>
        <exclusionTags>
            <li>Physique</li>
        </exclusionTags>
    </GeneDef>

    <!-- Beastman: Hooved -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_BeastmanHooved</defName>
        <label>hooved</label>
        <description>[Placeholder]</description>
