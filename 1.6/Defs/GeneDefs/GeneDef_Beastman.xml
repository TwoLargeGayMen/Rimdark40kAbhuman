        <displayOrderInCategory>82</displayOrderInCategory>

        <statOffsets>
            <MoveSpeed>0.3</MoveSpeed>
        </statOffsets>
        <conditionalStatAffecters>
            <li Class="Abhuman40k.ConditionalStatAffecter_FeetUncovered">
                <statOffsets>
                    <MoveSpeed>0.5</MoveSpeed>
                </statOffsets>
            </li>
            <li Class="Abhuman40k.ConditionalStatAffecter_FeetCovered">
                <statOffsets>
                    <MoveSpeed>-0.5</MoveSpeed>
                </statOffsets>
            </li>
        </conditionalStatAffecters>
    </GeneDef>

    <!-- Beastman: Horned -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_BeastmanHorned</defName>
        <label>horned</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Beastmen/BEWH_Horned</iconPath>
        <biostatCpx>1</biostatCpx>
        <biostatMet>0</biostatMet>
        <displayOrderInCategory>83</displayOrderInCategory>

        <exclusionTags>
            <li>Horn</li>
            <li>Horns</li>
        </exclusionTags>
        <renderNodeProperties>
            <li>
                <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
                <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
                <texPath>Things/Pawn/Humanlike/Beastman/HeadAttachments/Horns/BeastmanHorns</texPath>
                <color>
                    <r>0.5</r>
                    <g>0.5</g>
                    <b>0.5</b>
                    <a>1</a>
                </color>
                <parentTagDef>Head</parentTagDef>
                <drawData>
                    <defaultData>
                        <layer>80</layer>
                    </defaultData>
                    <dataNorth>
                        <layer>10</layer>
                        <offset>(0, -0.1, 0)</offset>
                    </dataNorth>
                </drawData>
            </li>
        </renderNodeProperties>
        <customEffectDescriptions>
            <li>Gives a horn attack</li>
        </customEffectDescriptions>
        <modExtensions>
            <li Class="VEF.Genes.GeneExtension">
                <hediffsToBodyParts>
                    <li>
                        <hediff>BEWH_BeastmanHornAttack</hediff>
                        <bodyparts>
                            <li>Head</li>
                        </bodyparts>
                    </li>
                </hediffsToBodyParts>
            </li>
        </modExtensions>
    </GeneDef>

