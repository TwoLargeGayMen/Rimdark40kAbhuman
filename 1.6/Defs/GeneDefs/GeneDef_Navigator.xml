<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Navigator: Warp Eye -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_NavigtorWarpEye</defName>
        <label>warp eye</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Navigator/BEWH_ThirdEye</iconPath>
        <geneClass>Core40k.Gene_GiveVEFAbility</geneClass>
        <biostatCpx>4</biostatCpx>
        <biostatMet>-3</biostatMet>
        <displayOrderInCategory>61</displayOrderInCategory>

        <exclusionTags>
            <li>Psyker</li>
            <li>Pariah</li>
        </exclusionTags>
        <capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>0.25</offset>
            </li>
            <li>
                <capacity>Sight</capacity>
                <offset>0.5</offset>
            </li>
        </capMods>
        <abilities>
            <li>BEWH_NavigatorExposeWarpEye</li>
        </abilities>
        <descriptionHyperlinks>
            <AbilityDef>BEWH_NavigatorExposeWarpEye</AbilityDef>
        </descriptionHyperlinks>
        <renderNodeProperties>
            <li>
                <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
                <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
                <texPath>Things/Pawn/Humanlike/Navigator/HeadAttachments/WarpEye/WarpEye</texPath>
                <parentTagDef>Head</parentTagDef>
                <visibleFacing>
                    <li>East</li>
                    <li>South</li>
                    <li>West</li>
                </visibleFacing>
                <drawData>
                    <defaultData>
                        <layer>60</layer>
                    </defaultData>
                </drawData>
            </li>
        </renderNodeProperties>
    </GeneDef>

    <!-- Navigator: Warp Navigation -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_NavigtorWarpNavigation</defName>
        <label>warp navigation</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Navigator/BEWH_WarpNavigation</iconPath>
        <geneClass>Core40k.Gene_GiveVEFAbility</geneClass>
        <biostatCpx>4</biostatCpx>
        <biostatMet>-2</biostatMet>
        <displayOrderInCategory>62</displayOrderInCategory>

        <statOffsets>
            <PilotingAbility MayRequire="Ludeon.RimWorld.Odyssey">1.33</PilotingAbility>
            <CaravanBonusSpeedFactor>0.2</CaravanBonusSpeedFactor>
        </statOffsets>
        <customEffectDescriptions>
            <li>Gives ability: Warp travel</li>
        </customEffectDescriptions>
        <descriptionHyperlinks>
            <VEF.Abilities.AbilityDef>BEWH_NavigatorWarpTravel</VEF.Abilities.AbilityDef>
        </descriptionHyperlinks>
        <modExtensions>
            <li Class="Core40k.DefModExtension_GivesVEFAbility">
                <abilityDefs>
                    <li>BEWH_NavigatorWarpTravel</li>
                </abilityDefs>
            </li>
        </modExtensions>
    </GeneDef>

    <!-- Navigator: Unsettling Presence -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_NavigtorUnsettlingPresence</defName>
        <label>unsettling presence</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Navigator/BEWH_UnsettlingPresence</iconPath>
        <biostatCpx>1</biostatCpx>
        <biostatMet>1</biostatMet>
        <displayOrderInCategory>63</displayOrderInCategory>

        <customEffectDescriptions>
            <li>Other pawns have decreased opinion of this pawn</li>
        </customEffectDescriptions>
    </GeneDef>

    <!-- Navigator: Long Lived -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_NavigtorLongLived</defName>
        <label>long lived</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Navigator/BEWH_Long-lived</iconPath>
        <biostatCpx>3</biostatCpx>
        <biostatMet>-1</biostatMet>
        <displayOrderInCategory>64</displayOrderInCategory>

        <biologicalAgeTickFactorFromAgeCurve>
            <points>
                <li>(18, 0.2)</li>
            </points>
        </biologicalAgeTickFactorFromAgeCurve>
    </GeneDef>

    <!-- Navigator: Navis Nobilite -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_NavigtorNavisNobilite</defName>
        <label>navis nobilite</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Navigator/BEWH_NavisNobilite</iconPath>
        <geneClass>Core40k.Gene_AddRandomGeneAndOrTraitByWeight</geneClass>
        <biostatCpx>1</biostatCpx>
        <biostatMet>-1</biostatMet>
        <displayOrderInCategory>65</displayOrderInCategory>

        <customEffectDescriptions>
            <li>Will belong to a noble navigator house</li>
        </customEffectDescriptions>

        <modExtensions>
            <li Class="Core40k.DefModExtension_AddRandomGeneByWeight">
                <possibleGenesToGive>
                    <li>
                        <key>BEWH_NavigtorHouseAchelieux</key>
                        <value>25</value>
                    </li>
                    <li>
                        <key>BEWH_NavigtorHouseBelisarius</key>
                        <value>25</value>
                    </li>
                    <li>
                        <key>BEWH_NavigtorHouseBrobantis</key>
                        <value>25</value>
                    </li>
                    <li>
                        <key>BEWH_NavigtorHouseCastana</key>
                        <value>25</value>
                    </li>
                </possibleGenesToGive>
                <addAsXenogene>false</addAsXenogene>
                <skipIfAnyAlreadyExistsOnPawn>true</skipIfAnyAlreadyExistsOnPawn>
            </li>
        </modExtensions>
    </GeneDef>

