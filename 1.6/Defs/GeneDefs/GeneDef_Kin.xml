<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Kin: Cloneskein -->
    <GeneDef ParentName="BEWH_AbhumanGenesOverallParent">
        <defName>BEWH_KinCloneskein</defName>
        <label>cloneskein</label>
        <description>[Placeholder]</description>
        <iconPath>UI/Genes/Kin/BEWH_Cloneskein</iconPath>
        <biostatCpx>4</biostatCpx>
        <biostatMet>-3</biostatMet>
        <displayOrderInCategory>41</displayOrderInCategory>
        <geneClass>Abhuman40k.Gene_Cloneskein</geneClass>
        <customEffectDescriptions>
            <li>Can be grown from a Crucible connected to an Ancestor Core.</li>
            <li>Can be uploaded to an Ancestor Core upon death, giving learning bonus to all living Kin.</li>
            <li>Will have a random Cloneskein mutation.</li>
        </customEffectDescriptions>
        <exclusionTags>
            <li>Psyker</li>
            <li>Pariah</li>
        </exclusionTags>
        <biologicalAgeTickFactorFromAgeCurve>
            <points>
                <li>(0, 10)</li>
                <li>(18, 1)</li>
            </points>
        </biologicalAgeTickFactorFromAgeCurve>
    </GeneDef>

