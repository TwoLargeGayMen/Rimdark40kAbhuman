            <li MayRequire="Ludeon.RimWorld.Ideology">AnimalPersonhood</li>
        </forcedMemes>
        <requiredPreceptsOnly MayRequire="Ludeon.RimWorld.Ideology">true</requiredPreceptsOnly>-->

        <earliestRaidDays>25</earliestRaidDays>
        <autoFlee>false</autoFlee>
        <raidCommonalityFromPointsCurve>
            <points>
                <li>(0, 1)</li>
            </points>
        </raidCommonalityFromPointsCurve>
        <maxPawnCostPerTotalPointsCurve>
            <points>
                <li>(0,0)</li>
                <li>(400, 100)</li>
                <li>(1000, 200)</li>
                <li>(2000, 400)</li>
                <li>(5000, 1000)</li>
                <li>(10000, 3000)</li>
                <li>(100000, 10000)</li>
            </points>
        </maxPawnCostPerTotalPointsCurve>
        <pawnGroupMakers>
            <!-- Mixed fight -->
            <li>
                <kindDef>Combat</kindDef>
                <commonality>100</commonality>
                <options>
                    <BEWH_BeastmanFactionBeastman>40</BEWH_BeastmanFactionBeastman>
                    <BEWH_BeastmanFactionMinotaur>10</BEWH_BeastmanFactionMinotaur>
                    <BEWH_BeastmanFactionChieftan>1</BEWH_BeastmanFactionChieftan>
                </options>
            </li>
            <!-- Beastman Horde -->
            <li>
                <kindDef>Combat</kindDef>
                <commonality>30</commonality>
                <options>
                    <BEWH_BeastmanFactionBeastman>1</BEWH_BeastmanFactionBeastman>
                </options>
            </li>
            <!-- Minotaur Squad -->
            <li>
                <kindDef>Combat</kindDef>
                <commonality>10</commonality>
                <options>
                    <BEWH_BeastmanFactionMinotaur>1</BEWH_BeastmanFactionMinotaur>
                </options>
            </li>
            <!-- Base defense -->
            <li>
                <kindDef>Settlement</kindDef>
                <options>
                    <BEWH_BeastmanFactionBeastman>14</BEWH_BeastmanFactionBeastman>
                    <BEWH_BeastmanFactionMinotaur>8</BEWH_BeastmanFactionMinotaur>
                    <BEWH_BeastmanFactionChieftan>1</BEWH_BeastmanFactionChieftan>
                </options>
            </li>
        </pawnGroupMakers>
    </FactionDef>


    <!-- Name of Beastman Faction -->
    <RulePackDef>
        <defName>BEWH_BeastmanFactionNameMaker</defName>
        <rulePack>
            <rulesStrings>
                <li>r_name->Beastmen Hordes</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <!-- Name of Imperium settlements -->
    <RulePackDef>
        <defName>BEWH_BeastmanSettlementNameMaker</defName>
        <rulePack>
            <rulesStrings>
                <li>r_name->[BEWH_BeastmanPre] [BEWH_BeastmanPost]</li>
            </rulesStrings>
            <rulesRaw>
                <li Class="Rule_File">
                    <keyword>BEWH_BeastmanPre</keyword>
                    <path>NameBanks/BEWH_BeastmanSettlementNamePre</path>
                </li>
                <li Class="Rule_File">
                    <keyword>BEWH_BeastmanPost</keyword>
                    <path>NameBanks/BEWH_BeastmanSettlementNamePost</path>
                </li>
            </rulesRaw>
        </rulePack>
    </RulePackDef>

</Defs>