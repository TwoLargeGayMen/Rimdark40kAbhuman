<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Make settlement fight always have a herdstone that also spawns more enemies? -->
    <FactionDef ParentName="FactionBase">
        <defName>BEWH_BeastmanFaction</defName>
        <label>Beastmen Horde</label>
        <description>A horde of vicious beastmen.</description>

        <pawnSingular>beastman</pawnSingular>
        <pawnsPlural>beastmen</pawnsPlural>
        <fixedLeaderKinds>
            <li>BEWH_BeastmanFactionChieftan</li>
        </fixedLeaderKinds>
        <leaderTitle>Chieftain</leaderTitle>
        <fixedName>Beastman Horde</fixedName>

        <settlementGenerationWeight>1</settlementGenerationWeight>
        <requiredCountAtGameStart>1</requiredCountAtGameStart>
        <allowedArrivalTemperatureRange>8~40</allowedArrivalTemperatureRange>
        <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
        <configurationListOrderPriority>91</configurationListOrderPriority>

        <canSiege>true</canSiege>
        <canStageAttacks>true</canStageAttacks>
        <permanentEnemy>false</permanentEnemy>
        <techLevel>Medieval</techLevel>
        <rescueesCanJoin>false</rescueesCanJoin>

        <factionNameMaker>BEWH_BeastmanFactionNameMaker</factionNameMaker>
        <settlementNameMaker>BEWH_BeastmanSettlementNameMaker</settlementNameMaker>
        <factionIconPath>UI/Misc/BEWH_BeastmenHorde</factionIconPath>
        <settlementTexturePath>UI/Misc/BEWH_BeastmenHorde</settlementTexturePath>
        <colorSpectrum>
            <li>(0.6, 0.3, 0.3)</li>
        </colorSpectrum>

        <xenotypeSet Inherit="False">
            <xenotypeChances>
                <BEWH_Beastman>0.9</BEWH_Beastman>
                <BEWH_Minotaur>0.1</BEWH_Minotaur>
            </xenotypeChances>
        </xenotypeSet>
        <backstoryFilters>
            <li>
                <categories>
                    <li>BEWH_BeastmanBackstoryPlayer</li>
                </categories>
            </li>
        </backstoryFilters>


        <!--<allowedCultures MayRequire="Ludeon.RimWorld.Ideology">
            <li>Corunan</li>
        </allowedCultures>

        <fixedIdeo MayRequire="Ludeon.RimWorld.Ideology">true</fixedIdeo>
        <ideoName MayRequire="Ludeon.RimWorld.Ideology">Dark gods worship</ideoName>
