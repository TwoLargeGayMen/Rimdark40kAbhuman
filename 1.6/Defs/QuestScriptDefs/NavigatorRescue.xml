<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <IncidentDef ParentName="GiveQuestBase">
        <defName>BEWH_NavigatorDowned</defName>
        <label>Downed Gravship</label>
        <questScriptDef>BEWH_NavigatorDowned</questScriptDef>
        <baseChance>0</baseChance> <!-- given by a special storyteller comp -->
    </IncidentDef>

    <QuestScriptDef>
        <defName>BEWH_NavigatorDowned</defName>
        <isRootSpecial>true</isRootSpecial>
        <defaultChallengeRating>1</defaultChallengeRating>
        <rootMinPoints>0</rootMinPoints>
        <rootIncreasesPopulation>true</rootIncreasesPopulation>
        <autoAccept>true</autoAccept>
        <questNameRules>
            <rulesStrings>
                <li>questName->Downed Gravship</li>
            </rulesStrings>
        </questNameRules>
        <questDescriptionRules>
            <rulesStrings>
                <li>questDescription(askerIsNull==true)->Long-range augurs have picked up a faint Mechanicus-pattern distress beacon. A gravship has come down hard and thermal signatures suggest imminent reactor failures and impossibly, a life sign sealed inside what looks like a Navigator's Sanctum.</li>
            </rulesStrings>
        </questDescriptionRules>
        <root Class="QuestNode_Sequence">
            <nodes>
                <li Class="QuestNode_SubScript">
                    <def>Util_AdjustPointsForDistantFight</def>
                </li>

                <li Class="QuestNode_GetMap">
                    <canBeSpace>false</canBeSpace>
                </li>

                <li Class="QuestNode_Set">
                    <name>askerIsNull</name>
                    <value>true</value>
                    <selectionWeight>1</selectionWeight>
                </li>

                <li Class="QuestNode_GetSiteTile">
                    <storeAs>siteTile</storeAs>
                    <preferCloserTiles>true</preferCloserTiles>
                </li>

                <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
                    <storeAs>sitePartDefs</storeAs>
                    <storeFactionAs>siteFaction</storeFactionAs>
                    <sitePartsTags>
                        <li>
                            <tag>BEWH_NavigatorDownedGravship</tag>
                        </li>
                        <li>
                            <tag>BEWH_NavigatorDowned</tag>
                        </li>
                        <li>
                            <tag>BEWH_NavigatorDownedAmbush</tag>
                        </li>
                    </sitePartsTags>
                </li>

                <li Class="QuestNode_GetDefaultSitePartsParams">
                    <tile>$siteTile</tile>
                    <faction>$siteFaction</faction>
                    <sitePartDefs>$sitePartDefs</sitePartDefs>
                    <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
                </li>

                <li Class="QuestNode_SubScript">
                    <def>Util_GenerateSite</def>
                    <parms>
                        <hiddenSitePartsPossible>true</hiddenSitePartsPossible>
                    </parms>
                </li>

                <li Class="QuestNode_SpawnWorldObjects">
                    <worldObjects>$site</worldObjects>
                </li>

                <li Class="QuestNode_WorldObjectTimeout">
                    <worldObject>$site</worldObject>
                    <isQuestTimeout>true</isQuestTimeout>
                    <delayTicks>$(randInt(7,15)*60000)</delayTicks>
                    <inSignalDisable>site.MapGenerated</inSignalDisable>
                    <node Class="QuestNode_Sequence">
                        <nodes>
                            <li Class="QuestNode_Letter">
                                <label TKey="LetterLabelQuestExpired">Quest expired: [resolvedQuestName]</label>
                                <text TKey="LetterTextQuestExpired">Distress signal have been lost, and report of a major explosion have been recieved, it is safe to say [refugee_nameDef] can no longer be rescued.</text>
                            </li>
                            <li Class="QuestNode_End">
                                <outcome>Fail</outcome>
                            </li>
                        </nodes>
                    </node>
                </li>

                <li Class="QuestNode_AddPawnReward">
                    <pawn>$navigator</pawn>
                    <inSignalChoiceUsed>site.MapGenerated</inSignalChoiceUsed>
                    <rewardDetailsHidden>true</rewardDetailsHidden>
                </li>

                <li Class="QuestNode_NoWorldObject">
                    <worldObject>$site</worldObject>
                    <node Class="QuestNode_End" />
                </li>
            </nodes>
        </root>
    </QuestScriptDef>

    <!-- Spawn Navigator -->
    <SitePartDef>
        <defName>BEWH_NavigatorDowned</defName>
        <label>incapacitated refugee</label>
        <description>A stranded, incapacitated refugee begging for help.</description>
        <workerClass>Abhuman40k.SitePartWorker_DownedNavigator</workerClass>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>World/WorldObjects/Expanding/Sites/DownedRefugee</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>16</forceExitAndRemoveMapCountdownDurationDays>
        <increasesPopulation>true</increasesPopulation>
        <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
        <gravShipsCanLandOn>true</gravShipsCanLandOn>
        <tags>
            <li>BEWH_NavigatorDowned</li>
        </tags>
    </SitePartDef>
    <GenStepDef>
        <defName>BEWH_NavigatorDowned</defName>
        <linkWithSite>BEWH_NavigatorDowned</linkWithSite>
        <order>1600</order>
        <genStep Class="Abhuman40k.GenStep_DownedNavigator">
            <count>1</count>
            <nearMapCenter>true</nearMapCenter>
        </genStep>
    </GenStepDef>

    <!-- Spawn Ambush -->
    <SitePartDef>
        <defName>BEWH_NavigatorDownedAmbush</defName>
        <label>ambush</label>
        <description>An ambush.</description>
        <workerClass>SitePartWorker_Ambush</workerClass>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>World/WorldObjects/Expanding/Sites/Ambush</expandingIconTexture>
        <defaultHidden>true</defaultHidden>
        <wantsThreatPoints>true</wantsThreatPoints>
        <tags>
            <li>BEWH_NavigatorDownedAmbush</li>
        </tags>
    </SitePartDef>
    <GenStepDef>
        <defName>BEWH_NavigatorDownedAmbush</defName>
        <linkWithSite>BEWH_NavigatorDownedAmbush</linkWithSite>
        <order>1600</order>
        <genStep Class="GenStep_Ambush_Edge" />
    </GenStepDef>

    <!-- Spawn Gravship -->
    <SitePartDef>
        <defName>BEWH_NavigatorDownedGravship</defName>
        <label>navigator gravship</label>
        <description>A navigator gravship.</description>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>World/WorldObjects/Expanding/Sites/DownedRefugee</expandingIconTexture>
        <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
        <tags>
            <li>BEWH_NavigatorDownedGravship</li>
        </tags>
    </SitePartDef>
    <GenStepDef>
        <defName>BEWH_NavigatorDownedGravship</defName>
        <linkWithSite>BEWH_NavigatorDownedGravship</linkWithSite>
        <order>460</order>
        <genStep Class="KCSG.GenStep_CustomStructureGen">
            <structureLayoutDefs>
                <li>BEWH_NavigatorGravshipNoOdyssey</li>
            </structureLayoutDefs>
            <!-- Additional options -->
            <fullClear>false</fullClear> <!-- Clear any impassable in the way -->
            <clearFogInRect>false</clearFogInRect> <!-- Clear fog on the structure -->
            <preventBridgeable>true</preventBridgeable> <!-- Prevent lake/river/marsh (bridgeable) -->
        </genStep>
    </GenStepDef>

