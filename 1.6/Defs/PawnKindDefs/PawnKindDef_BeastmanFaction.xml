        <maxGenerationAge>79</maxGenerationAge>
        <gearHealthRange>
            <min>1</min>
            <max>1</max>
        </gearHealthRange>
        <requiredWorkTags>
            <li>Violent</li>
        </requiredWorkTags>
        <fixedChildBackstories>
            <li>BEWH_BeastmanChild</li>
        </fixedChildBackstories>
        <fixedAdultBackstories>
            <li>BEWH_BeastmanAdult</li>
