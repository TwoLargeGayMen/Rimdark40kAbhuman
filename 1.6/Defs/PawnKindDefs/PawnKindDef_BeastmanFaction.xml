    <!-- Faction Beastman -->
    <PawnKindDef ParentName="BEWH_BeastmanPawnBase">
        <defName>BEWH_BeastmanFactionBeastman</defName>
        <label>beastman</label>
        <combatPower>20</combatPower>
        <initialWillRange>8~20</initialWillRange>
        <initialResistanceRange>8~20</initialResistanceRange>
        <fixedGender>Male</fixedGender>
        <skills>
            <li>
                <skill>Melee</skill>
                <range>6~9</range>
            </li>
        </skills>
        <xenotypeSet>
            <xenotypeChances>
                <BEWH_Beastman>1</BEWH_Beastman>
            </xenotypeChances>
        </xenotypeSet>
    </PawnKindDef>

    <!-- Faction Minotaur -->
    <PawnKindDef ParentName="BEWH_BeastmanPawnBase">
        <defName>BEWH_BeastmanFactionMinotaur</defName>
        <label>minotaur</label>
        <combatPower>60</combatPower>
