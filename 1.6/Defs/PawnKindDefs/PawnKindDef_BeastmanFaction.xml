            <li>
                <skill>Artistic</skill>
                <range>0~3</range>
            </li>
            <li>
                <skill>Crafting</skill>
                <range>0~3</range>
            </li>
            <li>
                <skill>Cooking</skill>
                <range>0~3</range>
            </li>
            <li>
                <skill>Construction</skill>
                <range>0~3</range>
            </li>
            <li>
                <skill>Animals</skill>
                <range>4~8</range>
            </li>
            <li>
                <skill>Shooting</skill>
                <range>2~5</range>
            </li>
