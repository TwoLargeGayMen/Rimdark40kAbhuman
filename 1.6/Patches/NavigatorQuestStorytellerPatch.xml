<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/StorytellerDef[@Name="BaseStoryteller"]/comps</xpath>
        <value>
            <li Class="StorytellerCompProperties_SingleOnceFixed">
                <fireAfterDaysPassed>50</fireAfterDaysPassed>
                <incident>BEWH_NavigatorDowned</incident>
                <skipIfOnExtremeBiome>true</skipIfOnExtremeBiome>
                <allowedTargetTags>
                    <li>World</li>
                </allowedTargetTags>
            </li>
        </value>
    </Operation>

</Patch>